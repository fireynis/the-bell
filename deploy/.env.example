# ─── Required ────────────────────────────────────────────────────────

# Password for the PostgreSQL database user (belluser)
POSTGRES_PASSWORD=changeme

# ─── Optional ────────────────────────────────────────────────────────

# Town name displayed in the UI header
TOWN_NAME=My Town

# Host port to expose the Bell app on
BELL_PORT=8080

# ─── Kratos URLs (override if using an external Kratos instance) ─────
# Normally you do NOT need to change these; they point to the bundled
# Kratos container on the internal Docker network.
#
# KRATOS_PUBLIC_URL=http://kratos:4433
# KRATOS_ADMIN_URL=http://kratos:4434

# ─── Public Base URL ─────────────────────────────────────────────────
# If you put Bell behind a reverse proxy with a custom domain, update
# the Kratos config (deploy/kratos/kratos.yml) so that browser-return
# URLs and CORS origins match your domain. For example, replace
# http://localhost:8080 with https://bell.example.com.
